# Public Supabase project URL, safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key, safe for browser use when Row Level Security is enabled.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Local app URL for Supabase magic-link redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only admin access. Do not prefix these with NEXT_PUBLIC_.
ADMIN_EMAIL=you@example.com
ADMIN_PASSCODE=change-this-private-passcode
ADMIN_SESSION_SECRET=change-this-long-random-secret
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
